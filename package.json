  "scripts": {
    "analyze": "RSDOCTOR=true rspack build --env production",
    "analyze:stats": "rspack build --env production --json js/stats.json",
    "build": "rspack build --env production",
    "dev": "rspack build --env development",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "serve": "rspack dev --env development",
    "stylelint": "stylelint \"src/**/*.scss\" \"src/**/*.vue\"",
    "stylelint:fix": "stylelint \"src/**/*.scss\" \"src/**/*.vue\" --fix",
    "test": "LANG=C vitest",
    "test:coverage": "LANG=C vitest run --coverage",
    "ts:check": "vue-tsc --noEmit",
    "ts:generate": "npx openapi-typescript -t",
    "ts:generate-core-types": "./src/types/generate-core-types.sh",
    "watch": "rspack build --env development --watch"
  },
